{
  "expo": {
    "name": "BuRandevu",
    "slug": "bu-randevu",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#eaeffe"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.burandevu",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "İşletmenizin konumunu belirlemek için konum erişimi gerekiyor.",
        "NSCameraUsageDescription": "İşletme fotoğrafı çekmek için kamera erişimi gerekiyor.",
        "NSPhotoLibraryUsageDescription": "İşletme galerisi için fotoğraf erişimi gerekiyor.",
        "NSPhotoLibraryAddUsageDescription": "Çekilen fotoğrafları kütüphaneye kaydetmek için erişim gerekiyor."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "8ca64c4b-ad97-4e61-a504-8203e182a2ee"
      }
    },
    "owner": "bu-randevu",
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1",
            "useFrameworks": "static",
            "forceStaticLinking": ["RNFBApp", "RNFBAuth"]
          }
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-image-picker",
        {
          "photosPermission": "İşletme galerisi için fotoğraf erişimi gerekiyor.",
          "cameraPermission": "İşletme fotoğrafı çekmek için kamera erişimi gerekiyor."
        }
      ]
    ]
  }
}
