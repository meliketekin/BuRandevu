rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Kullanıcı profil belgesi — sadece kendisi okur/yazar
    // İstisna: işletme sahibi kendi businessId'siyle eşleşen çalışan belgesi oluşturabilir
    match /users/{uid} {
      allow read, write: if request.auth.uid == uid;
      allow create: if request.auth != null
                    && request.resource.data.userType == 'business'
                    && request.resource.data.isAdmin == false
                    && request.resource.data.businessId == request.auth.uid;
    }

    // Favoriler — sadece kendi kullanıcısı okur/yazar
    match /users/{uid}/favorites/{businessId} {
      allow read, write: if request.auth.uid == uid;
    }

    // Kullanıcı randevu alt koleksiyonu — sadece kendisi okur/yazar
    // İstisna: işletme sahibi kendi randevusunun durumunu güncelleyebilir
    match /users/{uid}/appointments/{appointmentId} {
      allow read, write: if request.auth.uid == uid;
      allow update: if request.auth != null
                    && get(/databases/$(database)/documents/appointments/$(appointmentId)).data.businessId == request.auth.uid;
    }

    // İşletme bilgisi — herkes okuyabilir, sadece sahibi yazar
    match /businesses/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == uid;
    }

    // İşletmeye ait hizmet ve çalışan gibi alt koleksiyonlar
    // Herkes okuyabilir (müşteri randevu alımı için gerekli), sadece sahibi yazar
    // İstisna: çalışan kendi employee dokümanını (çalışma saatleri vb.) güncelleyebilir
    match /businesses/{uid}/{collection}/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == uid;
      allow update: if request.auth != null
                    && collection == "employees"
                    && docId == request.auth.uid
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == uid;
    }

    // Randevular — tek top-level koleksiyon
    // - Okuma:    giriş yapmış her kullanıcı okuyabilir
    //             (müşteriler slot çakışma kontrolü için diğer randevuların tarih/saat bilgisine ihtiyaç duyar)
    // - Oluşturma: giriş yapmış müşteri, status "pending" ve customerId kendi UID'si olmalı
    // - Güncelleme: işletme sahibi (onay/ret) VEYA müşteri (sadece iptal)
    match /appointments/{appointmentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.customerId == request.auth.uid
                    && request.resource.data.status == "pending";
      allow update: if request.auth != null
                    && (resource.data.businessId == request.auth.uid
                        || (resource.data.customerId == request.auth.uid
                            && request.resource.data.status == "cancelled"));
    }
  }
}
